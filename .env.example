# VinIQ — environment variables
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel, set this in Project Settings → Environment Variables instead.
# Never commit your actual API key — .env.local is already git-ignored.

# Required — used server-side only (app/api/analyze-*/route.ts).
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
